# DFIR AI Assistant - example environment
# Copy to .env and fill in

# LLM backend: "ollama" | "openai"
LLM_BACKEND=ollama

# Ollama Cloud settings (https://ollama.com)
# Get your key at: https://ollama.com/settings
OLLAMA_HOST=https://ollama.com/v1
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=glm-5.2

# Local Ollama settings (alternative)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI-compatible settings
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Paths (relative to project root)
DATA_DIR=./data
TURBOVEC_DIR=./data/turbovec
WIKI_TURBOVEC_DIR=./data/wiki/turbovec

# Pipeline defaults
PLASO_PARSERS=winevtx,winreg,prefetch,filestat
PLASO_VSS=none